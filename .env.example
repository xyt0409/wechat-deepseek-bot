# ===== 企业微信配置 =====

# 企业ID：我的企业 → 企业信息 → 最底部
WECOM_CORP_ID=ww1234567890abcdef

# 自建应用 AgentId 和 Secret：应用管理 → 点击你的应用
WECOM_AGENT_ID=1000002
WECOM_SECRET=你的Secret

# 回调配置（接收消息 → 设置API接收）
# Token：自己随便设，10位左右英文数字
WECOM_TOKEN=MyToken123

# EncodingAESKey：点"随机生成"按钮
WECOM_AES_KEY=你的43位EncodingAESKey


# ===== DeepSeek 配置 =====

# 在 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# 服务端口
PORT=5000
